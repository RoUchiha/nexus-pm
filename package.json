{
  "name": "nexus-pm",
  "version": "1.0.0",
  "description": "NEXUS AI Project Manager - autonomous agent orchestration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src tests api --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p tsconfig.api.json",
    "test": "vitest run",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run typecheck:api && npm run test && npm run build",
    "audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.19.0",
    "@clerk/backend": "^3.8.2",
    "@clerk/react": "^6.10.4",
    "@upstash/redis": "^1.35.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.8.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
