# Browser builds must never receive provider or connector secrets through VITE_* variables.
# Keep production source maps disabled unless publishing them to a private error-monitoring service.
VITE_ENABLE_SOURCEMAPS=false
VITE_AUTH0_DOMAIN=replace-me.us.auth0.com
VITE_AUTH0_CLIENT_ID=replace_me
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Marketplace aliases accepted by the build: CLERK_PUBLISHABLE_KEY or NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY

# Server-only settings. Configure these in the deployment platform, never in VITE_* variables.
AUTH0_DOMAIN=replace-me.us.auth0.com
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\nreplace_me\n-----END PUBLIC KEY-----"
# CLERK_SECRET_KEY can replace CLERK_JWT_KEY by enabling Clerk's remote JWKS verification.
CLERK_AUTHORIZED_PARTIES=https://nexus.example.com,http://localhost:5173
UPSTASH_REDIS_REST_URL=https://replace-me.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_me
# Marketplace aliases accepted by the API: KV_REST_API_URL and KV_REST_API_TOKEN
CONNECTOR_VAULT_KEY=replace_with_32_random_bytes_encoded_as_base64
CONNECTOR_ALLOWED_HOSTS=api.github.com,gitlab.com,api.example.com

# Enable only the providers your organization approves.
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LLM_REQUESTS_PER_MINUTE=30
LLM_REQUESTS_PER_DAY=2000
LLM_MAX_CONCURRENCY=4
LLM_DAILY_INPUT_CHARACTERS=5000000
